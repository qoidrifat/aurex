# =============================================================================
# AUREX .dockerignore — Mencegah file sensitif masuk Docker image
# =============================================================================

# --- Git ---
.git
.gitignore
.gitattributes
.github

# --- Environment ---
.env
.env.*
!env.example

# --- IDE ---
.idea
.vscode
*.swp
*.swo
.DS_Store

# --- Tests (tidak perlu di production image) ---
tests/
phpunit.xml
phpunit.xml.dist

# --- Node / Frontend (tidak diperlukan untuk backend-only image) ---
node_modules/
package.json
package-lock.json
vite.config.js
resources/js/
resources/css/

# --- Local dev tools ---
docker-compose.yml
docker-compose.*.yml
Makefile
Vagrantfile

# --- Logs & Cache ---
storage/logs/*
!storage/logs/.gitkeep
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php
!bootstrap/cache/.gitkeep

# --- Composer (akan di-copy dari build stage) ---
vendor/

# --- Dokumentasi (tidak perlu di production) ---
README.md
CHANGELOG.md
docs/
*.md

# --- File sementara ---
*.log
*.pid
*.sqlite
