APP_NAME=AUREX_API
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug
# Untuk production: LOG_CHANNEL=json (structured JSON logging)
# LOG_JSON_PATH=storage/logs/laravel.json

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aurex
DB_USERNAME=root
DB_PASSWORD=

# Redis (Cache, Session, Queue)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Laravel
BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
SESSION_LIFETIME=120

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:8000

# AI Service
AI_SERVICE_URL=http://ai-service:8001/analyze-face
AI_SERVICE_API_KEY=aurex-ai-dev-key-2026

# Firebase (optional)
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Sentry (Error Tracking)
SENTRY_LARAVEL_DSN=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_SEND_DEFAULT_PII=true

# Laravel Pulse (Performance Monitoring)
PULSE_ENABLED=true
PULSE_DB_CONNECTION=mysql

# Laravel Horizon (Queue Monitoring)
HORIZON_DOMAIN=
HORIZON_PATH=horizon

# Health Monitor Alerting
# ========================
HEALTH_ALERT_SLACK_ENABLED=false
HEALTH_ALERT_MAIL_ENABLED=false
HEALTH_ALERT_FAILURE_THRESHOLD=3
HEALTH_ALERT_RECOVERY_THRESHOLD=2
HEALTH_ALERT_LATENCY_WARNING=500
HEALTH_ALERT_LATENCY_CRITICAL=1000
HEALTH_ALERT_MAIL_RECIPIENTS=

# Slack (untuk notifikasi)
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

# Mail
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
