# ─── PRODUCTION ENVIRONMENT CONFIGURATION ─────────────
# Copy file ini ke .env untuk production deployment:
#   cp .env.production.example .env
#   php artisan key:generate
#
# Item #3 Bulan 3 — Production Configuration
# Semua nilai sudah dioptimasi untuk production.

APP_NAME=AUREX_API
APP_ENV=production
# GENERATE: php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.aurex.app

# ─── LOGGING ──────────────────────────────────────────
# Gunakan json channel untuk structured logging (ELK, Datadog, dll)
LOG_CHANNEL=json
LOG_LEVEL=warning
LOG_JSON_PATH=/var/www/html/storage/logs/laravel.json

# ─── DATABASE ─────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=aurex
DB_USERNAME=aurex_user
DB_PASSWORD=your_secure_password_here

# ─── REDIS (Cache, Session, Queue) ────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
CACHE_STORE=redis
# Cache TTL default (menit). Production: lebih panjang = performa lebih baik
CACHE_DEFAULT_TTL=3600
SESSION_DRIVER=redis
SESSION_LIFETIME=120
# Queue: gunakan redis dengan Horizon
QUEUE_CONNECTION=redis

# ─── LARAVEL ──────────────────────────────────────────
BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
FILESYSTEM_CLOUD=s3

# ─── SANCTUM (API Auth) ───────────────────────────────
SANCTUM_STATEFUL_DOMAINS=api.aurex.app
# Expiry untuk access tokens (menit). Default: 525600 (1 tahun)
SANCTUM_EXPIRATION=1440

# ─── AI SERVICE ───────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8001/analyze-face
AI_SERVICE_API_KEY=your_production_ai_key_here

# ─── SENTRY (Error Tracking) ──────────────────────────
SENTRY_LARAVEL_DSN=https://your-dsn@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# ─── LARAVEL PULSE (Performance Monitoring) ───────────
PULSE_ENABLED=true
PULSE_DB_CONNECTION=mysql
# Hanya collect data untuk performa
PULSE_RECORDINGS=true
PULSE_INGESTS=true
PULSE_INGEST_INTERVAL=60

# ─── LARAVEL HORIZON (Queue Monitoring) ───────────────
HORIZON_DOMAIN=queue.aurex.app
HORIZON_PATH=horizon

# ─── HEALTH MONITOR ───────────────────────────────────
HEALTH_ALERT_SLACK_ENABLED=true
HEALTH_ALERT_MAIL_ENABLED=true
HEALTH_ALERT_FAILURE_THRESHOLD=3
HEALTH_ALERT_RECOVERY_THRESHOLD=2
HEALTH_ALERT_LATENCY_WARNING=500
HEALTH_ALERT_LATENCY_CRITICAL=1000
HEALTH_ALERT_MAIL_RECIPIENTS=ops@aurex.app

# ─── SLACK (Notifications) ────────────────────────────
SLACK_BOT_USER_OAUTH_TOKEN=xoxb-your-slack-token
SLACK_BOT_USER_DEFAULT_CHANNEL=alerts-aurex

# ─── MAIL ─────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=your_sendgrid_api_key
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@aurex.app
MAIL_FROM_NAME="AUREX"

# ─── AWS (File Storage) ───────────────────────────────
# Opsional: gunakan S3 untuk file storage production
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=aurex-production
AWS_USE_PATH_STYLE_ENDPOINT=false
