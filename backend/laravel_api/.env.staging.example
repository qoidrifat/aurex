# ─── AUREX Staging Environment ─────────────────────────
# Copy file ini ke .env.staging dan isi semua nilai yang required.
#   cp .env.staging.example .env.staging
#
# Environment staging digunakan untuk pre-production testing
# sebelum deploy ke production. Gunakan database terpisah.

APP_NAME=AUREX_API_STAGING
APP_ENV=staging
APP_KEY=                                             # [REQUIRED] Generate: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://staging-api.aurex.app

# ─── Logging ──────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug
# Production: LOG_CHANNEL=json
# LOG_JSON_PATH=storage/logs/laravel.json

# ─── Database ─────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=aurex_staging
DB_USERNAME=aurex_user
DB_PASSWORD=                                           # [REQUIRED] Strong password untuk MySQL
DB_ROOT_PASSWORD=                                      # [REQUIRED] Root password MySQL

# ─── Redis (Cache, Session, Queue) ────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ─── Laravel ──────────────────────────────────────────
BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
SESSION_LIFETIME=120

# ─── Sanctum ──────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=staging-api.aurex.app,localhost:8000

# ─── AI Service ───────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8001/analyze-face
AI_SERVICE_API_KEY=                                    # [REQUIRED] Generate: openssl rand -hex 32

# ─── Sentry (Error Tracking) ──────────────────────────
SENTRY_LARAVEL_DSN=                                    # [OPTIONAL] Isi dengan Sentry DSN staging
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# ─── Laravel Pulse (Performance Monitoring) ───────────
PULSE_ENABLED=true
PULSE_DB_CONNECTION=mysql

# ─── Laravel Horizon (Queue Monitoring) ───────────────
HORIZON_DOMAIN=
HORIZON_PATH=horizon

# ─── Health Monitor Alerting ──────────────────────────
HEALTH_ALERT_SLACK_ENABLED=false
HEALTH_ALERT_MAIL_ENABLED=true
HEALTH_ALERT_FAILURE_THRESHOLD=3
HEALTH_ALERT_RECOVERY_THRESHOLD=2
HEALTH_ALERT_LATENCY_WARNING=500
HEALTH_ALERT_LATENCY_CRITICAL=1000
HEALTH_ALERT_MAIL_RECIPIENTS=                          # [OPTIONAL] Email untuk notifikasi health check

# ─── Slack (untuk notifikasi) ─────────────────────────
SLACK_BOT_USER_OAUTH_TOKEN=                            # [OPTIONAL]
SLACK_BOT_USER_DEFAULT_CHANNEL=                        # [OPTIONAL]

# ─── Mail ─────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@aurex.app
MAIL_FROM_NAME="${APP_NAME}"
