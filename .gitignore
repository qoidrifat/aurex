# ==================== PHP / Laravel ====================
/backend/laravel_api/.env
/backend/laravel_api/storage/framework/cache/data/*
/backend/laravel_api/storage/framework/sessions/*
/backend/laravel_api/storage/framework/views/*
/backend/laravel_api/storage/logs/*
/backend/laravel_api/vendor/
/backend/laravel_api/node_modules/
/backend/laravel_api/public/build/
/backend/laravel_api/public/hot

# ==================== Flutter / Dart ====================
mobile_app/flutter_app/.dart_tool/
mobile_app/flutter_app/.packages
mobile_app/flutter_app/.flutter-plugins
mobile_app/flutter_app/.flutter-plugins-dependencies
mobile_app/flutter_app/build/
mobile_app/flutter_app/coverage/
mobile_app/flutter_app/.pub-cache/
mobile_app/flutter_app/pubspec.lock

# ==================== Python / AI Service ==============
ai_service/python_ai/__pycache__/
ai_service/python_ai/*.pyc
ai_service/python_ai/venv/
ai_service/python_ai/.venv/
ai_service/python_ai/.pytest_cache/

# ==================== Docker ===========================
.docker/
docker-compose.override.yml

# ==================== Audit / Internal Docs ============
ROADMAP_PERBAIKAN_AUREX.md
HASIL_AUDIT_AUREX.md

