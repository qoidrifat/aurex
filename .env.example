# ============================================
# AUREX - Docker Compose Environment Variables
# ============================================
# Copy this file to .env and adjust values:
#   cp .env.example .env
#
# Then start the services:
#   docker-compose up -d
# ============================================

# --- Laravel ---
# Wajib! Generate dengan: cd backend/laravel_api && php artisan key:generate --show
APP_KEY=

# --- Database ---
DB_PASSWORD=aurex_secret_2026
DB_ROOT_PASSWORD=root_secret_2026

# --- AI Service ---
# API key untuk autentikasi antara Laravel backend dan AI Service.
# Wajib sama persis di kedua service (laravel + ai-service).
# Default: aurex-ai-dev-key-2026
AI_SERVICE_API_KEY=aurex-ai-dev-key-2026

# --- Sentry (Error Tracking) ---
SENTRY_DSN=

# --- Laravel Pulse ---
PULSE_ENABLED=true
